// 2. User / Admin Screen
void DrawRole(AppState* s, Font font)
{
    DrawCenteredText(font, "SELECT ACCOUNT TYPE", 110, 32, CLR_GREEN);

    // User Button
    if (IsButtonPressed(250, 220, 300, 50)) {
        s->isLoggingInAsAdmin = 0;   // User flag
